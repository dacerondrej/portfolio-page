---
const categories = [
  {
    name: "Languages",
    skills: ["TypeScript", "HTML", "CSS"],
  },
  {
    name: "Frameworks & Libraries",
    skills: ["React", "Astro", "Next.js"],
  },
  {
    name: "Styling",
    skills: ["Material UI", "Tailwind CSS", "SCSS"],
  },
  {
    name: "Tools",
    skills: ["Git", "Jira", "Figma", "Vite", "Rsbuild"],
  },
];
---

<section
  id="skills"
  class="py-24 border-t border-zinc-200 dark:border-zinc-900"
>
  <div class="max-w-4xl mx-auto px-6">
    <div class="reveal">
      <p class="text-sm font-medium text-mint mb-2 tracking-widest uppercase">
        Skills
      </p>
      <h2 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 mb-16">
        What I work with
      </h2>
    </div>

    <div class="grid sm:grid-cols-2 gap-10">
      {
        categories.map((cat, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1}`}>
            <h3 class="text-xs font-medium text-zinc-500 uppercase tracking-widest mb-4">
              {cat.name}
            </h3>
            <div class="flex flex-wrap gap-2">
              {cat.skills.map((skill) => (
                <span class="px-3 py-1.5 text-sm text-zinc-700 dark:text-zinc-300 bg-zinc-50 dark:bg-zinc-950 border border-zinc-300 dark:border-zinc-800 rounded-md hover:border-mint/60 hover:text-mint transition-colors duration-200 cursor-default">
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
