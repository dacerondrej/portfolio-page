---

<section id="experience" class="py-24">
  <div class="max-w-4xl mx-auto px-6">
    <div class="reveal">
      <p class="text-sm font-medium text-mint mb-2 tracking-widest uppercase">
        Experience
      </p>
      <h2 class="text-3xl font-semibold text-zinc-900 dark:text-zinc-100 mb-16">
        Where I've worked
      </h2>
    </div>

    <div class="space-y-12">
      {
        jobs.map((job, i) => (
          <div class={`reveal reveal-delay-${(i % 4) + 1} flex gap-8 group`}>
            <div class="hidden sm:block pt-1 w-36 shrink-0 text-right">
              <span class="text-xs text-zinc-500 tabular-nums">
                {job.period}
              </span>
            </div>
            <div class="flex gap-4">
              <div class="flex flex-col items-center">
                <div class="w-2 h-2 rounded-full bg-mint mt-2 shrink-0 group-hover:ring-4 ring-mint/20 transition-all duration-300" />
                <div class="w-px flex-1 bg-zinc-200 dark:bg-zinc-800 mt-2" />
              </div>
              <div class="pb-12">
                <p class="sm:hidden text-xs text-zinc-500 mb-1">{job.period}</p>
                <p class="text-xs text-zinc-500 font-medium uppercase tracking-wider mb-1">
                  {job.company}
                </p>
                <h3 class="text-lg font-medium text-zinc-900 dark:text-zinc-100 mb-3">
                  {job.role}
                </h3>
                <p class="text-zinc-600 dark:text-zinc-400 text-sm leading-relaxed mb-4">
                  {job.description}
                </p>
                <div class="flex flex-wrap gap-2">
                  {job.tags.map((tag) => (
                    <span class="px-2.5 py-1 text-xs font-medium text-mint bg-zinc-100 dark:bg-zinc-900 rounded-md">
                      {tag}
                    </span>
                  ))}
                </div>
              </div>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
